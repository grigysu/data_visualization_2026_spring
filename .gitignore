# Python.gitignore - curated for a typical Python project
# Customize as needed. Remove items you *do* want to track.

# Byte-compiled / optimized / DLL files
__pycache__/
*.py[cod]
*$py.class

# C extensions
*.so

# Distribution / packaging
build/
dist/
*.egg-info/
.eggs/
pip-wheel-metadata/

# Installer logs
pip-log.txt
pip-delete-this-directory.txt

# Virtual environments (common names)
venv/
ENV/
env/
.venv/
.env/
env.bak/

# pipenv / poetry
Pipfile.lock
.venv/
.pdm.toml

# PyInstaller
#  Usually these files are written by a python script from a template
*.manifest
*.spec

# Unit test / coverage reports
.pytest_cache/
.tox/
.coverage
.coverage.*
coverage.xml
htmlcov/

# MyPy / Pyre / PyType caches
.mypy_cache/
.pyre/
.pytype/

# Jupyter Notebook
.ipynb_checkpoints
*.nbconvert.ipynb

# IPython
profile_default/
ipython_config.py

# VS Code / JetBrains
.vscode/
.idea/

# OS files
.DS_Store
Thumbs.db

# Logs and temp files
*.log
*.tmp
*.temp

# SQLite local DB
*.sqlite3

# Sphinx / docs
docs/_build/

# Secrets and environment variables
.env
.env.*

# Optional: ignore generated interactive Plotly HTML (uncomment if you do not want to track them)
# figs/
# *.html

# Optional: ignore large data files (uncomment if you keep raw data out of git)
# data/
# *.csv
